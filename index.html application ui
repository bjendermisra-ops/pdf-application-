<style>
/* ================================================================
   TOOLGI v3.0 — PRODUCTION BUILD (FIXED & COMMENTED)
   ================================================================ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}

/* 
   👇 HINDI GUIDE (MAIN COLORS):
   Yahan sabhi main colors set kiye gaye hain. Agar aapko app ka theme badalna hai, 
   toh in HEX codes (#4F1271 wagera) ko change karein.
   --p: Primary Dark Color
   --acc: Accent (Chamakdar) Color
   --text: Text ka color
*/
:root{
  --p:#4F1271;--p2:#3a0d54;--acc:#783F8E;--soft:#BFACC8;
  --light:#f3eef8;--text:#1a1a2e;--sub:#6b7280;
  --nav-h:64px;--bar-h:58px;--drawer-w:285px;
  --r-pdf:#c0392b;--r-img:#2980b9;--r-seo:#27ae60;--r-fin:#d35400;
}
html{scroll-behavior:smooth}

/* FIX: Increased padding-bottom to 160px to solve the Bottom Tool Cutoff issue permanently */
body{font-family:'Poppins',sans-serif;background:#f3eef8;color:var(--text);overflow-x:hidden;padding-bottom:160px;-webkit-font-smoothing:antialiased}

/* ===== OVERLAY ===== */
/* Ye background me black shadow (blur) hai jo menu khulne par aata hai */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:800;opacity:0;pointer-events:none;transition:opacity .3s ease;backdrop-filter:blur(3px);-webkit-backdrop-filter:blur(3px)}
.overlay.show{opacity:1;pointer-events:all}

/* ===== SIDE DRAWER ===== */
/* Side se nikalne wala menu yahan se control hota hai */
.drawer{position:fixed;top:0;left:0;height:100%;width:var(--drawer-w);background:#fff;z-index:900;transform:translateX(-100%);transition:transform .32s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;overflow:hidden;box-shadow:6px 0 40px rgba(79,18,113,.3)}
.drawer.open{transform:translateX(0)}

.dh{background:linear-gradient(145deg,var(--p2) 0%,var(--acc) 100%);padding:44px 20px 22px;color:#fff;position:relative;flex-shrink:0}
.dh-close{position:absolute;top:14px;right:14px;width:32px;height:32px;background:rgba(255,255,255,.18);border:none;border-radius:50%;color:#fff;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s}
.dh-close:hover{background:rgba(255,255,255,.3)}
.dh-logo{width:56px;height:56px;background:rgba(255,255,255,.18);border-radius:16px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;border:2px solid rgba(255,255,255,.25);box-shadow:0 4px 12px rgba(0,0,0,.2)}
.dh-logo i{font-size:24px;color:#fff}
.dh-brand{font-size:22px;font-weight:900;letter-spacing:2.5px}
.dh-sub{font-size:11px;opacity:.75;font-weight:500;margin-top:3px}
.dh-badges{display:flex;gap:6px;margin-top:10px}
.dh-badge{font-size:9px;font-weight:700;padding:3px 8px;border-radius:99px;background:rgba(255,255,255,.18);color:rgba(255,255,255,.9)}

.db{flex:1;overflow-y:auto;padding:8px 0;scrollbar-width:none}
.db::-webkit-scrollbar{display:none}
.d-label{font-size:9.5px;font-weight:700;color:var(--sub);letter-spacing:1.2px;padding:14px 20px 5px;text-transform:uppercase}
.d-item{display:flex;align-items:center;gap:14px;padding:13px 20px;cursor:pointer;transition:background .18s;color:var(--text);text-decoration:none;font-size:13.5px;font-weight:600;border-left:3px solid transparent}
.d-item:hover,.d-item.dn-active{background:var(--light);border-left-color:var(--p);color:var(--p)}
.d-item .di{width:22px;text-align:center;font-size:15px;color:var(--acc)}
.d-item:hover .di,.d-item.dn-active .di{color:var(--p)}
.d-item .dc{margin-left:auto;font-size:9.5px;font-weight:700;padding:2px 8px;border-radius:99px;background:var(--light);color:var(--p)}
.d-divider{height:1px;background:rgba(79,18,113,.07);margin:8px 16px}
.d-footer{padding:14px 20px;border-top:1px solid rgba(79,18,113,.07);font-size:11px;color:var(--sub);text-align:center;flex-shrink:0}
.d-footer strong{color:var(--p)}

/* ===== PAGE OVERLAYS ===== */
.pg{display:none;position:fixed;inset:0;background:#f3eef8;z-index:950;overflow-y:auto}
.pg.show{display:block}
.pg-bar{background:var(--p);color:#fff;padding:14px 16px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:10;box-shadow:0 2px 10px rgba(0,0,0,.2)}
.pg-back{background:rgba(255,255,255,.18);border:none;border-radius:9px;color:#fff;padding:7px 12px;cursor:pointer;font-size:14px;transition:background .2s}
.pg-back:hover{background:rgba(255,255,255,.3)}
.pg-title{font-size:16px;font-weight:800;letter-spacing:.5px}
.pg-body{padding:20px 16px 30px}
.pg-body h3{font-size:14px;font-weight:700;color:var(--p);margin:18px 0 7px}
.pg-body h3:first-child{margin-top:0}
.pg-body p{font-size:13px;color:var(--sub);line-height:1.75;margin-bottom:8px}
.pg-stat{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:18px}
.pg-stat-box{background:var(--p);color:#fff;border-radius:14px;padding:16px;text-align:center}
.pg-stat-box .n{font-size:24px;font-weight:900}
.pg-stat-box .l{font-size:10px;opacity:.75;margin-top:2px;font-weight:600}
.contact-card{display:flex;align-items:center;gap:12px;padding:14px;background:#fff;border-radius:14px;margin-bottom:10px;box-shadow:0 2px 10px rgba(79,18,113,.08)}
.contact-card .cci{width:38px;height:38px;background:var(--light);border-radius:11px;display:flex;align-items:center;justify-content:center;color:var(--p);font-size:16px;flex-shrink:0}
.contact-card .ccl{font-size:13px;font-weight:700;color:var(--text)}
.contact-card .ccs{font-size:11.5px;color:var(--sub);margin-top:1px}

/* ===== APP BAR ===== */
/* 
   👇 HINDI GUIDE (TOP HEADER):
   Ye upar ka header jisme logo aur search bar hai. 
   Height badhani ho toh 'height' ko change kar sakte ho.
*/
.ab{position:sticky;top:0;z-index:500;height:var(--bar-h);background:var(--p);display:flex;align-items:center;padding:0 14px;gap:11px;box-shadow:0 3px 20px rgba(79,18,113,.5)}
.ab-menu{width:38px;height:38px;background:rgba(255,255,255,.15);border:1.5px solid rgba(255,255,255,.22);border-radius:11px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4.5px;cursor:pointer;flex-shrink:0;transition:background .2s;padding:0}
.ab-menu:hover{background:rgba(255,255,255,.25)}
.ab-menu span{display:block;width:16px;height:2px;background:#fff;border-radius:2px;transition:all .3s}
.ab-title{font-size:19px;font-weight:900;color:#fff;letter-spacing:2.5px;flex:1}
.ab-search{flex:1;max-width:210px;background:rgba(255,255,255,.14);border:1.5px solid rgba(255,255,255,.22);border-radius:99px;display:flex;align-items:center;padding:0 13px;gap:7px;height:36px}
.ab-search i{color:rgba(255,255,255,.6);font-size:12px;flex-shrink:0}
.ab-search input{background:none;border:none;outline:none;color:#fff;font-size:12.5px;font-family:'Poppins',sans-serif;width:100%}
.ab-search input::placeholder{color:rgba(255,255,255,.5)}

/* ===== CATEGORY PILLS ===== */
.cb{position:sticky;top:var(--bar-h);z-index:490;background:var(--p);padding:0 12px 10px;overflow-x:auto;display:flex;gap:8px;scrollbar-width:none;-webkit-overflow-scrolling:touch;border-bottom:2px solid rgba(255,255,255,.08)}
.cb::-webkit-scrollbar{display:none}
.cp{flex-shrink:0;padding:6px 15px;border-radius:99px;font-size:11.5px;font-weight:700;cursor:pointer;transition:all .22s;display:flex;align-items:center;gap:5px;border:1.5px solid rgba(255,255,255,.22);color:rgba(255,255,255,.65);background:transparent;white-space:nowrap;font-family:'Poppins',sans-serif}
.cp.active,.cp:active{background:#fff;color:var(--p);border-color:#fff;box-shadow:0 3px 12px rgba(0,0,0,.2)}
.cp i{font-size:11px}

/* ===== MAIN CONTENT ===== */
.ct{padding:14px 12px}
.sw{display:none}.sw.active{display:block}
#ss{display:none}#ss.show{display:block}

/* ===== SECTION HEADERS ===== */
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;margin-top:4px}
.st{font-size:15px;font-weight:800;color:var(--p);display:flex;align-items:center;gap:7px}
.si{width:27px;height:27px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:12px;color:#fff}
.see{font-size:11px;font-weight:700;color:var(--acc);padding:3px 10px;background:rgba(120,63,142,.12);border-radius:99px;cursor:pointer;transition:background .2s}
.see:hover{background:rgba(120,63,142,.2)}
.sd{height:1px;background:rgba(79,18,113,.08);margin:20px 0 16px}
.ssl{font-size:12px;font-weight:700;color:var(--sub);display:flex;align-items:center;gap:6px;margin:0 0 10px 2px}
.ssl i{color:var(--acc)}
.tab-header{display:flex;align-items:center;gap:10px;margin-bottom:16px}
.tab-count{font-size:11px;font-weight:700;color:var(--acc);padding:3px 10px;background:rgba(120,63,142,.1);border-radius:99px}

/* ===== STATS ROW ===== */
.sr{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:18px}
.sb{background:var(--p);border-radius:14px;padding:14px 8px;text-align:center;color:#fff;box-shadow:0 4px 14px rgba(79,18,113,.25)}
.sn{font-size:21px;font-weight:900}
.sl{font-size:10px;opacity:.7;font-weight:600;margin-top:2px}

/* ===== FEATURED STRIP ===== */
/* 
   👇 HINDI GUIDE (FEATURED SLIDER CARDS):
   Ye un cards ka design hai jo sabse upar horizontal scroll hote hain (e.g., Compress PDF).
   - Card ko aur bada ya chota karne ke liye 'width: 160px' aur 'height: 90px' ko badle.
   - Corners gol karne ke liye 'border-radius: 16px' ko change karein.
*/
.fs{margin-bottom:18px;overflow-x:auto;display:flex;gap:11px;scrollbar-width:none;padding-bottom:4px;-webkit-overflow-scrolling:touch}
.fs::-webkit-scrollbar{display:none}
.fc{flex-shrink:0;width:160px;height:90px;border-radius:16px;display:flex;flex-direction:column;justify-content:flex-end;padding:13px;text-decoration:none;color:#fff;position:relative;overflow:hidden;box-shadow:0 5px 18px rgba(0,0,0,.2)}
.fc::before{content:'';position:absolute;inset:0;background:rgba(0,0,0,.15)}
.fc-ico{position:absolute;right:12px;top:10px;font-size:26px;opacity:.85}
.fc-n{font-size:11.5px;font-weight:800;position:relative;z-index:1;text-shadow:0 1px 5px rgba(0,0,0,.35)}
.fc-s{font-size:9.5px;opacity:.85;position:relative;z-index:1;margin-top:1px}

/* ===== TOOL GRID ===== */
/* 
   👇 HINDI GUIDE (GRID):
   Agar ek line me 3 ki jagah 2 tools dikhane hain, toh 'repeat(3, 1fr)' ko 'repeat(2, 1fr)' kar de.
   'gap: 9px' se tools ke beech ki doori set hoti hai. 
*/
.tg{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:6px}

/* ===== TOOL CARD ===== */
/* 
   👇 HINDI GUIDE (MAIN TOOL CARD):
   Ye har ek tool ka dabbe ka design hai.
   - 'border-radius: 15px' ko change karke corners gol ya sharp karein.
   - 'min-height: 84px' ko badha kar cards ko aur lamba (tall) kar sakte hain.
*/
.tc{background:#fff;border-radius:15px;padding:14px 7px 12px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;text-decoration:none;color:var(--text);box-shadow:0 2px 8px rgba(79,18,113,.07);transition:transform .16s,box-shadow .16s;border:1.5px solid rgba(79,18,113,.05);position:relative;overflow:hidden;min-height:84px}
.tc:active{transform:scale(0.92);box-shadow:0 1px 3px rgba(79,18,113,.15)}
.tc .new-tag{position:absolute;top:6px;right:6px;font-size:7px;font-weight:800;background:linear-gradient(135deg,#ff6b6b,#c0392b);color:#fff;padding:2px 5px;border-radius:4px;letter-spacing:.5px}
.tc .hot-tag{position:absolute;top:6px;right:6px;font-size:7px;font-weight:800;background:linear-gradient(135deg,#f39c12,#d35400);color:#fff;padding:2px 5px;border-radius:4px;letter-spacing:.5px}

/* 
   👇 HINDI GUIDE (TOOL ICON BACKGROUND & SHAPE):
   Ye icon ka backgound box hai.
   - Ise aur bada karne ke liye 'width: 40px' aur 'height: 40px' ko badha dein (e.g. 50px).
   - Ise pura GOL (Circle) banane ke liye 'border-radius: 12px' ko 'border-radius: 50%' kar dein.
   - Icon ka apna size bada karne ke liye 'font-size: 18px' ko badha dein.
*/
.ti{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px}

/* 
   👇 HINDI GUIDE (TOOL NAME TEXT):
   Icon ke niche likha hua tool ka naam yahan se design hota hai.
   - 'font-size: 10px' ko badha kar 12px ya usse zyada kar sakte hain agar text chota lag raha ho.
*/
.tn{font-size:10px;font-weight:700;text-align:center;line-height:1.3;color:var(--text)}

/* Icon colors */
.ip{background:#fde8e8;color:#c0392b}
.ii{background:#e8f4fd;color:#2980b9}
.is{background:#e8fde8;color:#27ae60}
.if{background:#fdf5e8;color:#d35400}
.im{background:#f0e8fd;color:#8e44ad}
.ic{background:#e8fdf8;color:#16a085}

/* ===== RIPPLE ===== */
.rw{position:relative;overflow:hidden}
.rc{position:absolute;border-radius:50%;background:rgba(79,18,113,.13);transform:scale(0);animation:ra .55s linear;pointer-events:none}
@keyframes ra{to{transform:scale(4);opacity:0}}

/* ===== SEARCH ===== */
.nr{text-align:center;padding:48px 20px;color:var(--sub)}
.nr i{font-size:48px;color:var(--soft);margin-bottom:12px;display:block}
.nr h3{font-size:15px;font-weight:700;color:var(--p);margin-bottom:5px}

/* ===== BOTTOM NAV ===== */
.bn{position:fixed;bottom:0;left:0;right:0;height:var(--nav-h);background:var(--p2);border-top:1px solid rgba(255,255,255,.08);display:flex;z-index:600;box-shadow:0 -4px 24px rgba(0,0,0,.3)}
.ni{flex:1;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;cursor:pointer;transition:all .2s;position:relative;padding-top:3px}
.ni::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:0;height:3px;background:#fff;border-radius:0 0 5px 5px;transition:width .28s cubic-bezier(.34,1.56,.64,1)}
.ni.active::before{width:28px}
.ni-b{width:36px;height:26px;display:flex;align-items:center;justify-content:center;border-radius:99px;transition:all .22s}
.ni.active .ni-b{background:rgba(255,255,255,.15);width:44px}
.ni i{font-size:18px;color:rgba(255,255,255,.38);transition:all .22s}
.ni.active i{color:#fff;font-size:19px}
.ni span{font-size:10px;font-weight:600;color:rgba(255,255,255,.38);transition:color .22s;white-space:nowrap;letter-spacing:.3px}
.ni.active span{color:#fff;font-weight:700}
.ni:active{transform:scale(0.88)}

/* ===== SCROLL TOP ===== */
#stb{position:fixed;bottom:calc(var(--nav-h)+14px);right:14px;width:42px;height:42px;background:var(--p);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;box-shadow:0 4px 16px rgba(79,18,113,.45);opacity:0;transform:translateY(10px);transition:all .3s;pointer-events:none;cursor:pointer;z-index:400;border:none}
#stb.show{opacity:1;transform:translateY(0);pointer-events:all}

/* ===== TOAST ===== */
.toast{position:fixed;bottom:calc(var(--nav-h)+70px);left:50%;transform:translateX(-50%) translateY(20px);background:var(--p);color:#fff;font-size:13px;font-weight:600;padding:10px 20px;border-radius:99px;z-index:9999;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap;box-shadow:0 4px 16px rgba(79,18,113,.4)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ===== FAVORITES STRIP ===== */
.fav-strip{margin-bottom:16px;overflow-x:auto;display:flex;gap:8px;scrollbar-width:none;padding:2px 2px 4px}
.fav-strip::-webkit-scrollbar{display:none}
.fav-chip{flex-shrink:0;display:flex;align-items:center;gap:6px;padding:7px 12px;background:#fff;border-radius:99px;font-size:11px;font-weight:700;color:var(--p);text-decoration:none;box-shadow:0 2px 8px rgba(79,18,113,.1);border:1.5px solid rgba(79,18,113,.08);white-space:nowrap;transition:all .18s}
.fav-chip:active{background:var(--p);color:#fff}
.fav-chip i{font-size:11px}

/* ===== RECENTLY USED ===== */
.recent-section{margin-bottom:18px}
.recent-label{font-size:11.5px;font-weight:700;color:var(--sub);margin-bottom:8px;display:flex;align-items:center;gap:6px}
.recent-label i{color:var(--acc)}

/* ===== TOOL COUNT BADGE ===== */
.cat-count{font-size:10px;font-weight:700;color:var(--acc);padding:2px 8px;background:rgba(120,63,142,.1);border-radius:99px;margin-left:4px}

/* Animations */
@keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.sw.active .tg{animation:slideDown .2s ease-out}
</style>
</head>
<body>

