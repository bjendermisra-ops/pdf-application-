}
['pdf','image','seo','finance'].forEach(render);

document.getElementById('qi').addEventListener('input',function(){
  const q=this.value.trim().toLowerCase();
  const ss=document.getElementById('ss');
  if(!q){ss.classList.remove('show');goTab('home',document.querySelectorAll('.cp')[0]);return;}
  document.querySelectorAll('.sw').forEach(s=>s.classList.remove('active'));
  ss.classList.add('show');
  document.getElementById('sg').innerHTML=T.filter(t=>t.n.toLowerCase().includes(q)).map(t=>`<a href="${t.h}" class="tc rw"><div class="ti ${t.c}"><i class="${t.i}"></i></div><span class="tn">${t.n}</span></a>`).join('');
});

// --- SWIPE ---
let ts=0;
document.addEventListener('touchstart',e=>{ts=e.touches[0].clientX;},{passive:true});
document.addEventListener('touchend',e=>{
  const dx=e.changedTouches[0].clientX-ts;
  if(dx<-70&&document.getElementById('drawer').classList.contains('open'))closeDrawer();
  if(dx>70&&ts<30)openDrawer();
},{passive:true});
</script>
