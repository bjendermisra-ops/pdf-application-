<script>
// ============================================================
// TOOLGI v3.0 — PRODUCTION BUILD
// ============================================================

// ----- DRAWER -----
// 👇 HINDI GUIDE: Side menu kholne aur band karne ka code hai ye.
function openDrawer(){
  document.getElementById('drawer').classList.add('open');
  document.getElementById('overlay').classList.add('show');
  document.body.style.overflow='hidden';
}
function closeDrawer(){
  document.getElementById('drawer').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
  document.body.style.overflow='';
}

// ----- PAGES -----
// 👇 HINDI GUIDE: Jo popups app ke andar hi khulte hain unka function.
function openPage(id){
  closeDrawer();
  setTimeout(()=>{
    document.getElementById('pg-'+id).classList.add('show');
    document.body.style.overflow='hidden';
  },200);
}
function closePage(id){
  document.getElementById('pg-'+id).classList.remove('show');
  document.body.style.overflow='';
}

// ----- TOAST -----
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2200);
}

// ----- TAB SWITCH -----
function goTab(tab,pillEl){
  document.querySelectorAll('.sw').forEach(s=>s.classList.remove('active'));
  document.getElementById('ss').classList.remove('show');
  const t=document.getElementById('tab-'+tab);
  if(t)t.classList.add('active');
  if(pillEl){
    document.querySelectorAll('.cp').forEach(p=>p.classList.remove('active'));
    pillEl.classList.add('active');
    pillEl.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
  }
  document.querySelectorAll('[id^="dn-"]').forEach(i=>i.classList.remove('dn-active'));
  const dn=document.getElementById('dn-'+tab);
  if(dn)dn.classList.add('dn-active');
  document.getElementById('qi').value='';
  window.scrollTo({top:0,behavior:'smooth'});
}
function goTabDrawer(tab,el){
  goTab(tab,document.querySelector('[data-tab='+tab+']'));
  goNav(tab);
  document.querySelectorAll('.d-item').forEach(i=>i.classList.remove('dn-active'));
  el.classList.add('dn-active');
  closeDrawer();
}

// ----- BOTTOM NAV -----
function goNav(tab){
  document.querySelectorAll('.ni').forEach(n=>n.classList.remove('active'));
  const el=document.getElementById('ni-'+tab);
  if(el){el.classList.add('active');el.style.transform='scale(0.87)';setTimeout(()=>el.style.transform='',160);}
}

// ----- NATIVE SHARE FIXED -----
function shareApp(){
  if (window.Android && window.Android.shareApp) {
      window.Android.shareApp(); 
  } else if(navigator.share) {
      navigator.share({title: "Toolgi", url: "https://play.google.com/store/apps/details?id=com.plexa.santosh.in.hyper"});
  } else {
      showToast('Native Bridge Missing');
  }
  closeDrawer();
}

// ----- FAVORITES & RECENT (Preserved) -----
let favorites=JSON.parse(localStorage.getItem('tg_favs')||'[]');
function toggleFavorites(){closeDrawer();openPage('favorites');renderFavorites();}
function renderFavorites(){
  const g=document.getElementById('fav-grid'),e=document.getElementById('fav-empty');
  if(!favorites.length){g.innerHTML='';e.style.display='block';return;}
  e.style.display='none';
  g.innerHTML=favorites.map(t=>`<a href="${t.h}" class="tc rw"><div class="ti ${t.c}"><i class="${t.i}"></i></div><span class="tn">${t.n}</span></a>`).join('');
}
function addFavorite(tool){
  if(!favorites.find(f=>f.h===tool.h)){
    favorites.push(tool);localStorage.setItem('tg_favs',JSON.stringify(favorites));
    showToast('❤️ Added to Favorites!');
  } else {
    favorites=favorites.filter(f=>f.h!==tool.h);localStorage.setItem('tg_favs',JSON.stringify(favorites));
    showToast('Removed from Favorites');
  }
}
let recentTools=JSON.parse(localStorage.getItem('tg_recent')||'[]');
function addRecent(tool){
  recentTools=recentTools.filter(r=>r.h!==tool.h);
  recentTools.unshift(tool);
  if(recentTools.length>8)recentTools=recentTools.slice(0,8);
  localStorage.setItem('tg_recent',JSON.stringify(recentTools));
  renderRecent();
}
function renderRecent(){
  const sec=document.getElementById('recent-section'),strip=document.getElementById('recent-strip');
  if(!recentTools.length){sec.style.display='none';return;}
  sec.style.display='block';
  strip.innerHTML=recentTools.map(t=>`<a href="${t.h}" class="fav-chip"><i class="${t.i}"></i>${t.n}</a>`).join('');
}
renderRecent();

function clearData(){
  if(confirm('Clear all saved data?')){
    localStorage.removeItem('tg_favs');localStorage.removeItem('tg_recent');
    favorites=[];recentTools=[];renderRecent();showToast('✅ Data cleared!');
  }
  closeDrawer();
}

